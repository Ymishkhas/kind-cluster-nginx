{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": ["helmv3"],
  "helmv3": {
    "fileMatch": ["apps/[^/]+/Chart\\.yaml$"]
  },
  "dependencyDashboard": true,
  "semanticCommits": "enabled",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "additionalBranchPrefix": "{{replace 'clusters/' '' packageFileDir}}/",
  "addLabels": ["{{updateType}}"],
  "ignorePaths": [
    "clusters/*/apps/graylog/**"
  ],
  "packageRules": [
    {
      "description": "Ignore all internal chartmuseum dependencies",
      "matchRegistryUrls": ["@chartmuseum"],
      "enabled": false
    },
    {
      "description": "Istio - group base/istiod/gateway, must stay in sync",
      "matchPackageNames": ["base", "istiod", "gateway"],
      "matchRegistryUrls": ["https://istio-release.storage.googleapis.com/charts"],
      "groupName": "istio"
    }
  ]
}
